{
  "name": "gta-paris",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:client": "pnpm --filter @gta/client run dev",
    "dev:server": "pnpm --filter @gta/server run dev",
    "build": "pnpm --filter @gta/client run build",
    "start": "pnpm --filter @gta/server run start",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
